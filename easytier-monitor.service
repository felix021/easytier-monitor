[Unit]
Description=EasyTier Health Monitor
After=network.target easytier.service
Requires=easytier.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 -u /home/felix021/docker/easytier/easytier-monitor/monitor.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
